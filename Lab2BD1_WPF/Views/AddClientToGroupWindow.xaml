<Window x:Class="Lab2BD1_WPF.Views.AddClientToGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Запись на групповое занятие" Height="520" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F4F5F7">

    <Grid Margin="20">
        <materialDesign:Card Padding="20" Background="White" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtSessionTitle" Grid.Row="0" TextWrapping="Wrap" FontSize="16" FontWeight="Bold" Foreground="#4A90E2" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtSessionInfo" Grid.Row="1" TextWrapping="Wrap" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,12"/>

                <Border Grid.Row="2" BorderBrush="#E8EBEF" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="txtEnrolledHeader" Text="Записанные клиенты" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <ListBox x:Name="lbEnrolled" Grid.Row="1" MaxHeight="140" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding FullName}" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Contacts}" FontSize="11" Foreground="#95A5A6"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <ComboBox x:Name="cbClient" Grid.Row="3" materialDesign:HintAssist.Hint="Добавить клиента"
                          DisplayMemberPath="FullName" SelectedValuePath="Id"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,16"/>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Записать" Click="Save_Click" Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4A90E2" BorderBrush="#4A90E2" Width="110" Margin="0,0,10,0" Height="36"/>
                    <Button Content="Отмена" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Height="36"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
