<Window x:Class="Lab2BD1_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Управление расписанием и клиентами фитнес-клуба" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F4F5F7"
        Icon="/Logo/default.png">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E8EBEF" BorderThickness="0,0,1,0">
            <Grid Margin="24,20,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,32" HorizontalAlignment="Center">
                    <Image Source="/Logo/default.png" Height="70" Width="70" Margin="0,0,0,8"/>
                    <TextBlock Text="DDX-48 Фитнес" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtRole" FontSize="13" Foreground="#7F8C8D" Margin="0,6,0,0" HorizontalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock x:Name="txtUserFullName" FontSize="13" Foreground="#7F8C8D" Margin="0,4,0,0" HorizontalAlignment="Center" FontWeight="Medium" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="МЕНЮ" FontSize="14" Foreground="#95A5A6" FontWeight="Bold" Margin="12,0,0,12" HorizontalAlignment="Center"/>

                    <RadioButton x:Name="rbGroup" Style="{StaticResource MaterialDesignTabRadioButton}" IsChecked="True" 
                                 Height="50" Margin="0,0,0,6" Click="Tab_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Групповые занятия" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="rbPersonal" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Height="50" Margin="0,0,0,6" Click="Tab_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Dumbbell" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Персональные" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="rbClients" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Height="50" Margin="0,0,0,6" Click="Tab_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Клиенты" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="rbFinance" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Height="50" Margin="0,0,0,6" Click="Tab_Click" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CashMultiple" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Финансы" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Button x:Name="btnScheduleReport" Style="{StaticResource MaterialDesignRaisedButton}" Background="#4A90E2" BorderBrush="#4A90E2" Height="45" Click="Report_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileChart" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Отчёт по занятиям" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="btnSubscriptionReport" Style="{StaticResource MaterialDesignRaisedButton}" Background="#27AE60" BorderBrush="#27AE60"
                            Height="45" Margin="0,10,0,0" Click="SubscriptionReport_Click" Visibility="Collapsed">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CardAccountDetails" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Отчёт по абонементам" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button Content="Выход" Style="{StaticResource MaterialDesignOutlinedButton}" Height="45" Margin="0,10,0,0" Click="Logout_Click" Foreground="#E74C3C" BorderBrush="#E74C3C"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtPageTitle" Text="Расписание занятий" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="txtSearch" Width="260" Margin="0,0,12,0" TextChanged="Search_TextChanged" 
                             materialDesign:HintAssist.Hint="Поиск по ключевым словам..." 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:TextFieldAssist.HasClearButton="True" VerticalAlignment="Bottom"/>
                    <Button x:Name="btnUniversalAdd" Style="{StaticResource MaterialDesignRaisedAccentButton}" Content="+ Добавить" Click="UniversalAdd_Click" Height="40" Padding="16,0" VerticalAlignment="Bottom"/>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1" x:Name="MainTabs" BorderThickness="0" Background="Transparent">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="cbGroupActive" Content="Активные" Margin="0,0,16,0" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>
                            <CheckBox x:Name="cbGroupCancelled" Content="Отмененные" Margin="0,0,16,0" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>
                            <CheckBox x:Name="cbGroupFree" Content="Есть места" Margin="0,0,16,0" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>
                            <CheckBox x:Name="cbGroupBusy" Content="Мест нет" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>
                            <ComboBox x:Name="cbGroupTrainerFilter" Width="220" Margin="16,0,0,0"
                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                      SelectionChanged="TrainerFilter_SelectionChanged"
                                      materialDesign:HintAssist.Hint="Тренер"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>
                            <ComboBox x:Name="cbGroupTypeFilter" Width="180" Margin="12,0,0,0"
                                      SelectionChanged="GroupTypeFilter_SelectionChanged"
                                      materialDesign:HintAssist.Hint="Тип занятия"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>
                        </StackPanel>

                        <materialDesign:Card Grid.Row="1" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="8">
                            <DataGrid x:Name="dgSchedule" AutoGenerateColumns="False" IsReadOnly="True" 
                                      MouseDoubleClick="dgSchedule_MouseDoubleClick"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="12 10"
                                      SelectionMode="Single" HeadersVisibility="Column">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Записать клиента" Click="EnrollClientToGroup_Click">
                                            <MenuItem.Icon>
                                                <materialDesign:PackIcon Kind="AccountPlus"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="120" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Тренировка" Binding="{Binding Title}" Width="2*"/>
                                    <DataGridTextColumn Header="Тип занятия" Binding="{Binding Type}" Width="140"/>
                                    <DataGridTextColumn Header="Инструктор / Тренер" Binding="{Binding TrainerName}" Width="2*"/>
                                    <DataGridTextColumn Header="Места" Binding="{Binding Seats}" Width="100"/>
                                    <DataGridTemplateColumn x:Name="colGroupCancel" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Button Content="Отмена" Click="Cancel_Click" Padding="8,2" Height="28" BorderBrush="#E74C3C" Foreground="#E74C3C">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanCancel}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Setter Property="Opacity" Value="0.4"/>
                                                                        <Setter Property="Content" Value="Отменено"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <TextBlock Text="-" FontSize="20" FontWeight="Bold" Foreground="#95A5A6"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanCancel}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="cbPersonalActive" Content="Активные" Margin="0,0,16,0" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>
                            <CheckBox x:Name="cbPersonalCancelled" Content="Отмененные" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>
                            <ComboBox x:Name="cbPersonalTrainerFilter" Width="280" Margin="16,0,0,0"
                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                      SelectionChanged="TrainerFilter_SelectionChanged"
                                      materialDesign:HintAssist.Hint="Тренер"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>
                        </StackPanel>

                        <materialDesign:Card Grid.Row="1" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="8">
                            <DataGrid x:Name="dgPersonal" CanUserAddRows="False" AutoGenerateColumns="False" IsReadOnly="True" 
                                      MouseDoubleClick="dgPersonal_MouseDoubleClick"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="12 10" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата/время" Binding="{Binding DateTime, StringFormat=dd.MM.yyyy HH:mm}" Width="180" IsReadOnly="True" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="2*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Тренер" Binding="{Binding TrainerName}" Width="2*" IsReadOnly="True"/>
                                    <DataGridTemplateColumn x:Name="colPersonalStatus" Header="Статус (Активна)" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <CheckBox IsChecked="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Click="PersonalStatus_Click" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanEditStatus}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>
                                                    <TextBlock Text="-" FontSize="20" FontWeight="Bold" Foreground="#95A5A6"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanEditStatus}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="cbClientHasContacts" Content="Только с заполненными контактами" Margin="0,0,0,12" Click="FilterChanged_Click" Style="{StaticResource MaterialDesignCheckBox}"/>

                        <materialDesign:Card Grid.Row="1" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="8">
                            <DataGrid Grid.Row="1" x:Name="dgClients" CanUserAddRows="False" AutoGenerateColumns="False" RowEditEnding="dgClients_RowEditEnding" materialDesign:DataGridAssist.CellPadding="10">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="История платежей" Click="ClientPayments_Click">
                                            <MenuItem.Icon>
                                                <materialDesign:PackIcon Kind="CashMultiple"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="2*"/>

                                    <DataGridTextColumn Header="Контакты" Binding="{Binding Contacts, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="2*"/>

                                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding Birthday, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=dd.MM.yyyy}" Width="140"/>

                                    <DataGridTextColumn Header="Регистрация" Binding="{Binding RegistrationDate, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=dd.MM.yyyy}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ComboBox x:Name="cbFinanceMethodFilter" Width="220" Margin="0,0,0,12"
                                  SelectionChanged="FinanceFilter_SelectionChanged"
                                  materialDesign:HintAssist.Hint="Способ оплаты"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>

                        <materialDesign:Card Grid.Row="1" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="8">
                            <DataGrid x:Name="dgFinance" AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      materialDesign:DataGridAssist.CellPadding="12 10" HeadersVisibility="Column"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="60"/>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="110" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="2*"/>
                                    <DataGridTextColumn Header="Контакты" Binding="{Binding ClientContacts}" Width="*"/>
                                    <DataGridTextColumn Header="Назначение" Binding="{Binding Purpose}" Width="2*"/>
                                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" Width="110"/>
                                    <DataGridTextColumn Header="Способ" Binding="{Binding Method}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>
            </TabControl>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtCounter" Foreground="#7F8C8D" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>

                <StackPanel x:Name="pnlPagination" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnPrevPage" Content="Назад" Click="PrevPage_Click" Margin="0,0,8,0" Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Padding="12,0"/>
                    <TextBlock x:Name="txtPageInfo" VerticalAlignment="Center" Margin="8,0,16,0" FontWeight="SemiBold" Foreground="#2C3E50" FontSize="13"/>
                    <Button x:Name="btnNextPage" Content="Вперед" Click="NextPage_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Padding="12,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
