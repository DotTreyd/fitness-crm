<Window x:Class="Lab2BD1_WPF.Views.EditTrainingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Редактировать занятие" Height="530" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F4F5F7">

    <Grid Margin="16">
        <materialDesign:Card Padding="20" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="8" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Редактирование занятия" FontSize="18" FontWeight="Bold" Foreground="#4A90E2" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBox x:Name="txtTitle" materialDesign:HintAssist.Hint="Название"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                             materialDesign:TextFieldAssist.HasClearButton="True" Margin="0,0,0,15"/>

                    <DatePicker x:Name="dpDate" materialDesign:HintAssist.Hint="Дата проведения"
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Margin="0,0,0,15"/>

                    <ComboBox x:Name="cbType" materialDesign:HintAssist.Hint="Тип занятия"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,15">
                        <ComboBoxItem Content="Групповая"/>
                        <ComboBoxItem Content="Персональная"/>
                    </ComboBox>

                    <ComboBox x:Name="cbInstructor" materialDesign:HintAssist.Hint="Тренер"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,15"/>

                    <TextBox x:Name="txtSeats" materialDesign:HintAssist.Hint="Количество мест"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                             materialDesign:TextFieldAssist.HasClearButton="True" Margin="0,0,0,15"/>

                    <CheckBox x:Name="chkCancelled" Content="Пометка отмены (префикс &quot;ОТМЕНА:&quot;)"
                              Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,0,15"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Click="Save_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="#4A90E2" BorderBrush="#4A90E2" Width="110" Margin="0,0,10,0" Height="36"/>
                    <Button Content="Отмена" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#7F8C8D" Height="36"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>