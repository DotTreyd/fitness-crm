<Window x:Class="Lab2BD1_WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStartupLocation="CenterScreen"
        Title="DDX-48 Фитнес — вход" Height="640" Width="400"
        Background="Transparent" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="16" Background="#F0F4FA" BorderBrush="#D5DFED" BorderThickness="1"
            materialDesign:ShadowAssist.ShadowDepth="Depth4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="16,16,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A90E2" Offset="0"/>
                        <GradientStop Color="#357ABD" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,20">
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32" Padding="0"
                            Style="{StaticResource MaterialDesignIconButton}" Foreground="White" Opacity="0.85"
                            Click="Exit_Click" ToolTip="Закрыть">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Logo/default.png" Height="56" Width="56" Margin="0,0,0,8"/>
                        <TextBlock Text="DDX-48 Фитнес" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Управление расписанием и клиентами" FontSize="12" Foreground="#E8F4FF"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <materialDesign:Card Grid.Row="1" Margin="15,15,15,15" Padding="28,12" UniformCornerRadius="12"
                                 Background="White" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                <StackPanel>
                    <TextBlock Text="Вход в систему" FontSize="20" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                    <TextBlock Text="Введите учётные данные" FontSize="13" Foreground="#95A5A6" Margin="0,0,0,20"/>

                    <TextBox x:Name="txtLogin" materialDesign:HintAssist.Hint="Логин (email / номер тренера)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,14"
                             materialDesign:TextFieldAssist.HasClearButton="True"/>

                    <PasswordBox x:Name="txtPassword" materialDesign:HintAssist.Hint="Пароль"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Margin="0,0,0,16"/>

                    <Border Background="#F8FAFC" CornerRadius="8" Padding="12" Margin="0,0,0,20" BorderBrush="#E8EBEF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Подсказка" FontWeight="SemiBold" FontSize="12" Foreground="#4A90E2" Margin="0,0,0,6"/>
                            <TextBlock FontSize="11.5" Foreground="#7F8C8D" TextWrapping="Wrap" LineHeight="18">
                                <Run FontWeight="SemiBold" Foreground="#5D6D7E">Администратор:</Run>
                                <LineBreak/>
                                <Run>Логин: Ваш e-mail</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="SemiBold" Foreground="#5D6D7E">Тренер:</Run>
                                <LineBreak/>
                                <Run>Логин: Номер тренера</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Button Content="ВОЙТИ" Click="Login_Click" Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4A90E2" BorderBrush="#4A90E2" Margin="0,0,0,8"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Border>
</Window>
