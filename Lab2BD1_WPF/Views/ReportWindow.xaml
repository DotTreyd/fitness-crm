<Window x:Class="Lab2BD1_WPF.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Отчёт по занятиям" Height="720" Width="1150"
        WindowStartupLocation="CenterScreen" Background="#F7F9FC">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="15" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Занятия и записи за период" FontSize="18" FontWeight="Bold" Foreground="#4A90E2"/>
                <TextBlock Text="Сводка по групповым и персональным занятиям, отменам и загруженности тренеров." FontSize="12" Foreground="#7F8C8D" Margin="0,4,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <DatePicker x:Name="dpStart" materialDesign:HintAssist.Hint="С даты" Width="150" Margin="0,0,16,0"
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                    <DatePicker x:Name="dpEnd" materialDesign:HintAssist.Hint="По дату" Width="150" Margin="0,0,16,0"
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                    <Button Content="Сформировать" Click="Generate_Click" Background="#4A90E2" Foreground="White" Height="36" Padding="16,0"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <materialDesign:Card Margin="0,0,8,0" Padding="12" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Групповые (активные)" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtGroupCount" Text="—" FontSize="22" FontWeight="Bold" Foreground="#4A90E2"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,8,0" Padding="12" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Персональные (активные)" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtPersonalCount" Text="—" FontSize="22" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,8,0" Padding="12" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Отменено" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtCancelledCount" Text="—" FontSize="22" FontWeight="Bold" Foreground="#E74C3C"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Padding="12" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Самый активный тренер" FontSize="11" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtTopTrainer" Text="—" FontSize="16" FontWeight="SemiBold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <TabControl Grid.Row="2" x:Name="tabsReport" Margin="0,0,0,12">
            <TabItem Header="Все записи">
                <DataGrid x:Name="dgAll" AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{StaticResource MaterialDesignDataGrid}" materialDesign:DataGridAssist.CellPadding="8"/>
            </TabItem>
            <TabItem Header="Групповые">
                <DataGrid x:Name="dgGroups" AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{StaticResource MaterialDesignDataGrid}" materialDesign:DataGridAssist.CellPadding="8"/>
            </TabItem>
            <TabItem Header="Персональные">
                <DataGrid x:Name="dgPersonals" AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{StaticResource MaterialDesignDataGrid}" materialDesign:DataGridAssist.CellPadding="8"/>
            </TabItem>
            <TabItem Header="Отменённые">
                <DataGrid x:Name="dgCancelled" AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{StaticResource MaterialDesignDataGrid}" materialDesign:DataGridAssist.CellPadding="8"/>
            </TabItem>
            <TabItem Header="По тренерам">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="pnlByTrainer" Margin="8"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3">
            <TextBlock x:Name="txtSummary" VerticalAlignment="Center" Foreground="#7F8C8D" FontWeight="Medium"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить HTML" Click="Export_Click" Background="#27AE60" Foreground="White" Width="150" Height="36"/>
                <Button Content="Сохранить PDF" Click="ExportPdf_Click" Background="#4A90E2" Foreground="White" Width="150" Height="36" Margin="10,0,0,0"/>
                <Button Content="Закрыть" Click="Close_Click" Style="{StaticResource MaterialDesignFlatButton}" Margin="10,0,0,0" Height="36"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

