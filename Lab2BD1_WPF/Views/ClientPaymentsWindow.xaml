<Window x:Class="Lab2BD1_WPF.Views.ClientPaymentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="История платежей" Height="480" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F4F5F7">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtClientTitle" Grid.Row="0" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
        <TextBlock x:Name="txtSummary" Grid.Row="1" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,12"/>

        <materialDesign:Card Grid.Row="2" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" UniformCornerRadius="8">
            <DataGrid x:Name="dgPayments" AutoGenerateColumns="False" IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      materialDesign:DataGridAssist.CellPadding="12 10" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="60"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="110" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Назначение" Binding="{Binding Purpose}" Width="2*"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" Width="110"/>
                    <DataGridTextColumn Header="Способ оплаты" Binding="{Binding Method}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <Button Grid.Row="3" Content="Закрыть" HorizontalAlignment="Right" Margin="0,16,0,0"
                IsCancel="True" Style="{StaticResource MaterialDesignRaisedButton}"
                Background="#4A90E2" BorderBrush="#4A90E2" Width="120" Height="36"/>
    </Grid>
</Window>
