<Window x:Class="Lab2BD1_WPF.Views.AddPersonalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Новое занятие" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Персональная тренировка" FontSize="18" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,0,20"/>

            <ComboBox x:Name="cbClient" materialDesign:HintAssist.Hint="Выберите клиента" 
                      DisplayMemberPath="FullName" SelectedValuePath="Id"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,15"/>

            <ComboBox x:Name="cbInstructor" materialDesign:HintAssist.Hint="Выберите тренера" 
                      DisplayMemberPath="Name" SelectedValuePath="Id"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,15"/>

            <DatePicker x:Name="dpDate" materialDesign:HintAssist.Hint="Дата" 
                        Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Margin="0,0,0,15"/>

            <TextBox x:Name="txtTime" materialDesign:HintAssist.Hint="Время (напр. 14:30)" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,25"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Записать" Click="Save_Click" Background="#27AE60" Width="100" Margin="0,0,10,0"/>
                <Button Content="Отмена" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>